<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App identity -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>TerrainMapper</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Device / OS requirements -->
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer><!-- iPhone only -->
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
        <string>arkit</string>
    </array>
    <key>MinimumOSVersion</key>
    <string>17.0</string>

    <!-- Supported orientations (portrait + landscape for field use) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Privacy usage descriptions — required for App Store / iOS permission dialogs -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>TerrainMapper needs your location to record GPS coordinates for each survey point.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>TerrainMapper uses your location continuously during field surveys to maintain accurate positioning.</string>
    <key>NSMotionUsageDescription</key>
    <string>TerrainMapper uses the accelerometer, gyroscope, and barometer to stabilise altitude measurements and detect when the device is stationary.</string>
    <key>NSCameraUsageDescription</key>
    <string>TerrainMapper uses the camera and LiDAR scanner to measure the distance from the device to the ground surface.</string>

    <!-- Launch screen — REQUIRED for full-screen rendering on all iPhones.
         Without this key, iOS renders the app in a legacy letterboxed
         compatibility mode with black bars on top and bottom. An empty
         dictionary gives a plain colour launch screen (uses the system
         background) which is fine for a SwiftUI app that loads instantly. -->
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Scene configuration (default SwiftUI lifecycle) -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                </dict>
            </array>
        </dict>
    </dict>

    <!-- Background modes needed for continuous location during surveys -->
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
    </array>
</dict>
</plist>
